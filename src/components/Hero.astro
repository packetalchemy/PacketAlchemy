---

---

<section class="relative overflow-hidden">

  <!-- Background Glow -->
  <div class="absolute -left-64 -top-64 w-[700px] h-[700px] rounded-full bg-blue-600/20 blur-[180px]"></div>

  <div class="absolute -right-64 bottom-0 w-[700px] h-[700px] rounded-full bg-blue-500/20 blur-[180px]"></div>

  <!-- Grid -->
  <div
    class="absolute inset-0 opacity-10
    bg-[linear-gradient(rgba(255,255,255,.06)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.06)_1px,transparent_1px)]
    bg-[size:48px_48px]"
  ></div>

  <div class="relative max-w-7xl mx-auto px-8 pt-28 pb-20">

    <!-- Badge -->

    <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/10 px-5 py-2 text-sm text-blue-300">

      <span class="h-2 w-2 rounded-full bg-blue-400"></span>

      Telecom Knowledge Platform

    </div>

    <!-- Hero -->

    <div class="mt-12 max-w-5xl">

      <h1 class="text-6xl md:text-8xl font-black leading-[0.95] tracking-tight">

        Engineering

        <br />

        Telecom Systems

        <br />

        <span class="text-blue-500">
          at Scale
        </span>

      </h1>

      <p class="mt-10 max-w-3xl text-xl leading-9 text-gray-400">

        PacketAlchemy is a modern engineering knowledge base focused on
        5G Core, EPC, DNS, Diameter, Cloudflare, Linux,
        Open Source and real-world telecom troubleshooting.

      </p>

      <!-- Buttons -->

      <div class="flex flex-wrap gap-5 mt-12">

        <a
          href="/blog"
          class="rounded-xl bg-blue-600 hover:bg-blue-500 transition px-8 py-4 font-semibold shadow-lg shadow-blue-600/20"
        >
          Explore Articles →
        </a>

        <a
          href="https://github.com/packetalchemy"
          target="_blank"
          class="rounded-xl border border-gray-700 hover:border-blue-500 hover:bg-gray-900 transition px-8 py-4"
        >
          GitHub →
        </a>

      </div>

    </div>

    <!-- Stats -->

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mt-24 max-w-4xl">

      <div>

        <div class="text-5xl font-black text-blue-500">
          20+
        </div>

        <div class="text-gray-400 mt-2">
          Years Experience
        </div>

      </div>

      <div>

        <div class="text-5xl font-black text-blue-500">
          5G
        </div>

        <div class="text-gray-400 mt-2">
          Core Engineering
        </div>

      </div>

      <div>

        <div class="text-5xl font-black text-blue-500">
          OSS
        </div>

        <div class="text-gray-400 mt-2">
          Open Source Projects
        </div>

      </div>

    </div>

    <!-- Feature Cards -->

    <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-8 mt-24">

      <div
        class="rounded-2xl border border-gray-800 bg-[#111827]/60 backdrop-blur p-7 hover:border-blue-500 hover:-translate-y-2 transition-all duration-300"
      >

        <div class="text-2xl mb-4">📡</div>

        <h3 class="text-xl font-semibold">
          5G Core
        </h3>

        <p class="mt-4 text-gray-400 leading-7">

          AMF, SMF, UPF, NRF, NSSF,
          UE Registration,
          PDU Session,
          SBA Architecture.

        </p>

      </div>

      <div
        class="rounded-2xl border border-gray-800 bg-[#111827]/60 backdrop-blur p-7 hover:border-blue-500 hover:-translate-y-2 transition-all duration-300"
      >

        <div class="text-2xl mb-4">🛡️</div>

        <h3 class="text-xl font-semibold">
          EPC
        </h3>

        <p class="mt-4 text-gray-400 leading-7">

          MME,
          SGW,
          PGW,
          GTP,
          Diameter,
          S11,
          S5/S8,
          Troubleshooting.

        </p>

      </div>

      <div
        class="rounded-2xl border border-gray-800 bg-[#111827]/60 backdrop-blur p-7 hover:border-blue-500 hover:-translate-y-2 transition-all duration-300"
      >

        <div class="text-2xl mb-4">☁️</div>

        <h3 class="text-xl font-semibold">
          Cloud & Automation
        </h3>

        <p class="mt-4 text-gray-400 leading-7">

          Cloudflare,
          Docker,
          Workers,
          Linux,
          Python,
          Automation,
          Open Source.

        </p>

      </div>

      <div
        class="rounded-2xl border border-gray-800 bg-[#111827]/60 backdrop-blur p-7 hover:border-blue-500 hover:-translate-y-2 transition-all duration-300"
      >

        <div class="text-2xl mb-4">🌐</div>

        <h3 class="text-xl font-semibold">
          Network Protocols
        </h3>

        <p class="mt-4 text-gray-400 leading-7">

          Diameter,
          GTP,
          PFCP,
          NAS,
          NGAP,
          HTTP/2,
          HTTP/3,
          QUIC,
          DNS.

        </p>

      </div>

    </div>

  </div>

</section>