---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";

interface Props {
  title?: string;
}

const { title = "PacketAlchemy" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
</head>

<body class="bg-[#0b0f17] text-white min-h-screen">

  <Navbar />

  <main>
    <slot />
  </main>

</body>

</html>

---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<div class="min-h-screen bg-[#0b0f17] text-white">

    <Navbar />

    <main>

        <slot />

    </main>

    <Footer />

</div>